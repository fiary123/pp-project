# =============================================================
# 智慧宠物养护与领养管理系统 — 环境变量示例
# 复制此文件为 .env 并填入真实值，切勿将 .env 提交到版本库
# =============================================================

# ── JWT 安全密钥（必填，启动时若未设置会直接报错）──────────────────────
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Token 有效期（分钟），默认 60；调试时可改为 1440（24 小时）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI 模型配置 ───────────────────────────────────────────────────────
# 模型分工：
#   DeepSeek → 所有纯文本 Agent（匹配/营养/评估/知识问答/对话）
#   Qwen-VL  → 仅分诊模块有图片/视频输入时的视觉分析（可选）
#
# DeepSeek（必填）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
#
# Qwen-VL（选填，不填时分诊模块自动降级为纯文本模式）
# 在阿里云百炼控制台获取：https://bailian.console.aliyun.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── CORS 跨域白名单（逗号分隔）────────────────────────────────────────
# 本地开发默认值，生产环境替换为实际域名
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# ── 高德地图 API Key（宠物医院搜索功能）──────────────────────────────
AMAP_KEY=
